# ── Supabase ────────────────────────────────────────────────
# Creá un proyecto en https://supabase.com y copiá estos valores
# desde Project Settings → API. Luego renombrá este archivo a .env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor — NO exponer al cliente. Para tareas admin/seed.
SUPABASE_SERVICE_ROLE_KEY=

# ── Mercado Pago ────────────────────────────────────────────
# Credentials → https://www.mercadopago.com.ar/developers/panel
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# ── Cloudinary (opcional) ───────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
